{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "moduleDetection": "force",
    "strict": true,
    "noImplicitOverride": true,
    "exactOptionalPropertyTypes": true,
    "noUncheckedIndexedAccess": true,
    "useDefineForClassFields": true,
    "isolatedModules": true,
    "verbatimModuleSyntax": true,
    "skipLibCheck": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "composite": true,
    "paths": {
      "@jue/shared": [
        "./packages/shared/src/index.ts"
      ],
      "@jue/runtime-core": [
        "./packages/runtime-core/src/index.ts"
      ],
      "@jue/runtime-core/channel": [
        "./packages/runtime-core/src/channel.ts"
      ],
      "@jue/runtime-core/reactivity": [
        "./packages/runtime-core/src/reactivity.ts"
      ],
      "@jue/runtime-core/host-contract": [
        "./packages/runtime-core/src/host-contract.ts"
      ],
      "@jue/compiler": [
        "./packages/compiler/src/index.ts"
      ],
      "@jue/compiler/frontend": [
        "./packages/compiler/src/frontend/index.ts"
      ],
      "@jue/compiler/ir": [
        "./packages/compiler/src/ir.ts"
      ],
      "@jue/compiler/lowering": [
        "./packages/compiler/src/lowering.ts"
      ],
      "@jue/compiler/builder": [
        "./packages/compiler/src/builder.ts"
      ],
      "@jue/jsx": [
        "./packages/jsx/src/index.ts"
      ],
      "@jue/primitives": [
        "./packages/primitives/src/index.ts"
      ],
      "@jue/authoring-check": [
        "./packages/authoring-check/src/index.ts"
      ],
      "@jue/stream": [
        "./packages/stream/src/index.ts"
      ],
      "@jue/router": [
        "./packages/router/src/index.ts"
      ],
      "@jue/query": [
        "./packages/query/src/index.ts"
      ],
      "@jue/devtrace": [
        "./packages/devtrace/src/index.ts"
      ],
      "@jue/docsgen": [
        "./packages/docsgen/src/index.ts"
      ],
      "@jue/web": [
        "./packages/web/src/index.ts"
      ],
      "@jue/native": [
        "./packages/native/src/index.ts"
      ],
      "@jue/skyline": [
        "./packages/skyline/src/index.ts"
      ],
      "@jue/examples": [
        "./packages/examples/src/index.ts"
      ],
      "@jue/inspect": [
        "./packages/inspect/src/index.ts"
      ],
      "@jue/testkit": [
        "./packages/testkit/src/index.ts"
      ],
      "@jue/bench": [
        "./packages/bench/src/index.ts"
      ]
    }
  }
}
