{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "moduleDetection": "force",
    "strict": true,
    "noImplicitOverride": true,
    "exactOptionalPropertyTypes": true,
    "noUncheckedIndexedAccess": true,
    "useDefineForClassFields": true,
    "isolatedModules": true,
    "verbatimModuleSyntax": true,
    "skipLibCheck": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "composite": true,
    "paths": {
      "@jue/shared": [
        "./packages/kernel/shared/src/index.ts"
      ],
      "@jue/runtime-core": [
        "./packages/kernel/runtime-core/src/index.ts"
      ],
      "@jue/runtime-core/channel": [
        "./packages/kernel/runtime-core/src/channel.ts"
      ],
      "@jue/runtime-core/reactivity": [
        "./packages/kernel/runtime-core/src/reactivity.ts"
      ],
      "@jue/runtime-core/host-contract": [
        "./packages/kernel/runtime-core/src/host-contract.ts"
      ],
      "@jue/compiler": [
        "./packages/kernel/compiler/src/index.ts"
      ],
      "@jue/compiler/frontend": [
        "./packages/kernel/compiler/src/frontend/index.ts"
      ],
      "@jue/compiler/ir": [
        "./packages/kernel/compiler/src/ir.ts"
      ],
      "@jue/compiler/lowering": [
        "./packages/kernel/compiler/src/lowering.ts"
      ],
      "@jue/compiler/builder": [
        "./packages/kernel/compiler/src/builder.ts"
      ],
      "@jue/jsx": [
        "./packages/authoring/jsx/src/index.ts"
      ],
      "@jue/primitives": [
        "./packages/authoring/primitives/src/index.ts"
      ],
      "@jue/authoring-check": [
        "./packages/authoring/authoring-check/src/index.ts"
      ],
      "@jue/stream": [
        "./packages/stdlib/stream/src/index.ts"
      ],
      "@jue/router": [
        "./packages/stdlib/router/src/index.ts"
      ],
      "@jue/query": [
        "./packages/stdlib/query/src/index.ts"
      ],
      "@jue/devtrace": [
        "./packages/tooling/devtrace/src/index.ts"
      ],
      "@jue/docsgen": [
        "./packages/tooling/docsgen/src/index.ts"
      ],
      "@jue/web": [
        "./packages/host/web/src/index.ts"
      ],
      "@jue/native": [
        "./packages/host/native/src/index.ts"
      ],
      "@jue/skyline": [
        "./packages/host-target/skyline/src/index.ts"
      ],
      "@jue/examples": [
        "./packages/tooling/examples/src/index.ts"
      ],
      "@jue/inspect": [
        "./packages/tooling/inspect/src/index.ts"
      ],
      "@jue/testkit": [
        "./packages/tooling/testkit/src/index.ts"
      ],
      "@jue/bench": [
        "./packages/tooling/bench/src/index.ts"
      ]
    }
  }
}
