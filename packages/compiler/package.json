{
  "name": "@jue/compiler",
  "version": "0.0.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "dependencies": {
    "@jue/runtime-core": "workspace:*",
    "@jue/shared": "workspace:*"
  },
  "scripts": {
    "build": "esbuild src/index.ts --bundle --format=esm --platform=node --outfile=dist/index.js --sourcemap && tsc -p tsconfig.json --emitDeclarationOnly --outDir dist",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  }
}
