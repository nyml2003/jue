{
  "name": "@jue/runtime-core",
  "version": "0.0.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./channel": {
      "types": "./dist/channel.d.ts",
      "import": "./dist/channel.js"
    },
    "./host-contract": {
      "types": "./dist/host-contract.d.ts",
      "import": "./dist/host-contract.js"
    },
    "./reactivity": {
      "types": "./dist/reactivity.d.ts",
      "import": "./dist/reactivity.js"
    }
  },
  "dependencies": {
    "@jue/shared": "workspace:*"
  },
  "scripts": {
    "build": "jue-cli",
    "test": "jue-cli",
    "typecheck": "jue-cli"
  },
  "jueCli": [
    { "phase": "build", "mode": "library", "platform": "neutral", "minify": ["index"] },
    { "phase": "typecheck", "mode": "tsc" },
    { "phase": "test", "mode": "test", "coverageConfig": "vitest.coverage-all.config.ts" }
  ]
}
