{
  "name": "@jue/compiler",
  "version": "0.0.0",
  "type": "module",
  "main": "./dist/index.js",
  "bin": {
    "jue-compile": "./dist/cli.js"
  },
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./builder": {
      "types": "./dist/blueprint-builder.d.ts",
      "import": "./dist/blueprint-builder.js"
    },
    "./frontend": {
      "types": "./dist/frontend/index.d.ts",
      "import": "./dist/frontend/index.js"
    },
    "./ir": {
      "types": "./dist/block-ir.d.ts",
      "import": "./dist/block-ir.js"
    },
    "./lowering": {
      "types": "./dist/block-ir.d.ts",
      "import": "./dist/block-ir.js"
    }
  },
  "dependencies": {
    "@babel/generator": "^7.29.1",
    "@babel/parser": "^7.29.2",
    "@babel/traverse": "^7.29.0",
    "@babel/types": "^7.29.0",
    "@jue/runtime-core": "workspace:*",
    "@jue/shared": "workspace:*"
  },
  "devDependencies": {
    "@types/babel__generator": "^7.27.0",
    "@types/babel__traverse": "^7.28.0"
  },
  "scripts": {
    "build": "jue-cli",
    "test": "jue-cli",
    "typecheck": "jue-cli"
  },
  "jueCli": [
    { "phase": "build", "mode": "library", "platform": "node", "minify": ["index", "frontend"], "extraEntries": ["src/cli.ts"] },
    { "phase": "typecheck", "mode": "tsc" },
    { "phase": "test", "mode": "test", "coverageConfig": "vitest.coverage-all.config.ts" }
  ]
}
