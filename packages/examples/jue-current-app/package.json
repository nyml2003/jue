{
  "name": "jue-current-app",
  "private": true,
  "type": "module",
  "scripts": {
    "compile": "tsx scripts/compile.ts",
    "dev": "pnpm run compile && vite",
    "build": "jue-cli",
    "preview": "pnpm run build && vite preview",
    "typecheck": "jue-cli"
  },
  "dependencies": {
    "@jue/jsx": "workspace:*",
    "@jue/runtime-core": "workspace:*",
    "@jue/web": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^24.5.2",
    "tsx": "^4.19.3",
    "typescript": "^5.8.3",
    "vite": "^6.4.2"
  },
  "jueCli": [
    { "phase": "build", "mode": "vite", "preBuild": "pnpm run compile" },
    { "phase": "typecheck", "mode": "tsc", "pretty": false }
  ]
}
