{
  "name": "@jue/authoring-check",
  "version": "0.0.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "dependencies": {
    "@jue/compiler": "workspace:*",
    "@jue/primitives": "workspace:*"
  },
  "scripts": {
    "build": "jue-cli",
    "test": "jue-cli",
    "typecheck": "jue-cli"
  },
  "jueCli": [
    { "phase": "build", "mode": "library", "platform": "node", "minify": false },
    { "phase": "typecheck", "mode": "tsc" },
    { "phase": "test", "mode": "test", "coverageConfig": "vitest.coverage-all.config.ts" }
  ]
}
