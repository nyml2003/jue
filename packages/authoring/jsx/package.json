{
  "name": "@jue/jsx",
  "version": "0.0.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "dependencies": {
    "@jue/primitives": "workspace:*",
    "@jue/shared": "workspace:*"
  },
  "scripts": {
    "build": "jue-cli",
    "typecheck": "jue-cli"
  },
  "jueCli": [
    { "phase": "build", "mode": "library", "platform": "neutral", "minify": ["index"] },
    { "phase": "typecheck", "mode": "tsc" }
  ]
}
