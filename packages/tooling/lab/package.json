{
  "name": "@jue/lab",
  "version": "0.0.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./examples": {
      "types": "./dist/examples.d.ts",
      "import": "./dist/examples.js"
    },
    "./inspect": {
      "types": "./dist/inspect.d.ts",
      "import": "./dist/inspect.js"
    },
    "./testkit": {
      "types": "./dist/testkit.d.ts",
      "import": "./dist/testkit.js"
    },
    "./bench": {
      "types": "./dist/bench.d.ts",
      "import": "./dist/bench.js"
    }
  },
  "dependencies": {
    "@jue/compiler": "workspace:*",
    "@jue/shared": "workspace:*"
  },
  "scripts": {
    "bench": "pnpm exec tsx ./src/cli.ts bench",
    "compile-examples": "pnpm exec tsx ./src/cli.ts compile-examples",
    "build": "jue-cli",
    "typecheck": "jue-cli"
  },
  "jueCli": [
    { "phase": "build", "mode": "library", "platform": "node", "minify": false, "extraEntries": ["src/cli.ts", "src/compile-examples.ts"] },
    { "phase": "typecheck", "mode": "tsc" }
  ]
}
