{
  "name": "jue-workspace",
  "private": true,
  "packageManager": "pnpm@10.10.0",
  "scripts": {
    "build": "pnpm -r --filter \"./packages/*\" run build",
    "compile:components": "pnpm exec tsx ./scripts/compile-example-components.ts",
    "size:packages": "pnpm build && node ./scripts/report-package-sizes.mjs",
    "typecheck": "pnpm exec tsc -p tsconfig.check.json --noEmit --pretty false",
    "lint": "eslint .",
    "test": "node ./node_modules/vitest/vitest.mjs run",
    "dev": "pnpm --filter @jue/web-playground dev",
    "bench": "pnpm --filter @jue/web-playground run build"
  },
  "devDependencies": {
    "@types/node": "^24.5.2",
    "@eslint/js": "^9.25.0",
    "esbuild": "^0.25.3",
    "eslint": "^9.25.0",
    "globals": "^16.0.0",
    "jsdom": "^26.1.0",
    "tsx": "^4.19.3",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.30.1",
    "vite": "^6.3.2",
    "vitest": "^3.1.1"
  }
}
