{
  "name": "jue-workspace",
  "private": true,
  "packageManager": "pnpm@10.10.0",
  "bin": {
    "jue-cli": "jue-cli.js"
  },
  "scripts": {
    "build": "jue-cli",
    "compile:components": "pnpm exec tsx ./scripts/compile-example-components.ts",
    "build:examples": "pnpm --filter @jue/web-playground build",
    "docs": "pnpm --filter @jue/docsgen docsgen",
    "lint": "jue-cli",
    "typecheck": "jue-cli",
    "test": "jue-cli",
    "test:scripts": "node ./node_modules/vitest/vitest.mjs run --config ./vitest.scripts.config.ts --coverage",
    "test:e2e": "pnpm --filter @jue/web-playground test:e2e",
    "dev": "pnpm --filter @jue/web-playground preview",
    "bench": "pnpm --filter @jue/lab bench"
  },
  "jueCli": [
    { "phase": "build", "mode": "workspace", "post": "pnpm build:examples" },
    { "phase": "lint", "mode": "eslint" },
    { "phase": "typecheck", "mode": "tsc", "tsconfig": "tsconfig.check.json", "pretty": false },
    { "phase": "test", "mode": "test", "coverageConfig": "vitest.coverage-all.config.ts" }
  ],
  "devDependencies": {
    "jue-cli": "link:./scripts",
    "@eslint/js": "^9.25.0",
    "@types/node": "^24.5.2",
    "@vitest/coverage-v8": "^3.2.4",
    "esbuild": "^0.25.3",
    "eslint": "^9.25.0",
    "globals": "^16.0.0",
    "jsdom": "^26.1.0",
    "tsx": "^4.19.3",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.30.1",
    "vite": "^6.3.2",
    "vitest": "^3.1.1"
  }
}
