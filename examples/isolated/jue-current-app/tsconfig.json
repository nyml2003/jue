{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "jsx": "preserve",
    "allowImportingTsExtensions": true,
    "baseUrl": ".",
    "paths": {
      "@jue/compiler/*": ["../../../packages/compiler/src/*"],
      "@jue/compiler": ["../../../packages/compiler/src/index.ts"],
      "@jue/jsx": ["../../../packages/jsx/src/index.ts"],
      "@jue/primitives": ["../../../packages/primitives/src/index.ts"],
      "@jue/runtime-core": ["../../../packages/runtime-core/src/index.ts"],
      "@jue/shared": ["../../../packages/shared/src/index.ts"],
      "@jue/web": ["../../../packages/web/src/index.ts"]
    },
    "types": ["node"]
  },
  "include": [
    "scripts/**/*.ts",
    "src/**/*.ts",
    "src/**/*.tsx",
    "vite.config.ts"
  ]
}
