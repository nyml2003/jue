{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "jsx": "preserve",
    "rootDir": "../..",
    "outDir": "dist",
    "lib": [
      "ES2022",
      "DOM"
    ],
    "types": [
      "vite/client",
      "node"
    ]
  },
  "include": [
    "apps/**/*.ts",
    "apps/**/*.tsx",
    "runtime/**/*.ts",
    "scripts/**/*.ts",
    "vite-env.d.ts",
    "../../packages/shared/src/**/*.ts",
    "../../packages/runtime-core/src/**/*.ts",
    "../../packages/compiler/src/**/*.ts",
    "../../packages/jsx/src/**/*.ts",
    "../../packages/jsx/src/**/*.d.ts",
    "../../packages/web/src/**/*.ts",
    "../../packages/primitives/src/**/*.ts",
    "../../packages/authoring-check/src/**/*.ts",
    "../../packages/stream/src/**/*.ts",
    "../../packages/router/src/**/*.ts",
    "../../packages/query/src/**/*.ts",
    "../../packages/devtrace/src/**/*.ts",
    "../../packages/docsgen/src/**/*.ts",
    "../../packages/examples/src/**/*.ts",
    "../../packages/inspect/src/**/*.ts",
    "../../packages/testkit/src/**/*.ts",
    "../../packages/bench/src/**/*.ts"
  ]
}
