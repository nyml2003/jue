{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "jsx": "preserve",
    "rootDir": "../..",
    "outDir": "dist",
    "lib": [
      "ES2022",
      "DOM"
    ],
    "types": [
      "vite/client"
    ]
  },
  "include": [
    "src/**/*.ts",
    "src/**/*.tsx",
    "src/**/*.d.ts",
    "../../packages/shared/src/**/*.ts",
    "../../packages/runtime-core/src/**/*.ts",
    "../../packages/compiler/src/**/*.ts",
    "../../packages/jsx/src/**/*.ts",
    "../../packages/jsx/src/**/*.d.ts",
    "../../packages/web/src/**/*.ts"
  ]
}
