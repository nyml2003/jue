{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "baseUrl": ".",
    "noEmit": true,
    "composite": false,
    "jsx": "preserve",
    "lib": [
      "ES2022",
      "DOM"
    ]
  },
  "include": [
    "packages/**/*.ts",
    "packages/**/*.tsx",
    "examples/**/*.ts",
    "examples/**/*.tsx"
  ],
  "exclude": [
    "dist",
    "node_modules",
    ".omx"
  ]
}
